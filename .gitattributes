# Normalize line endings to LF on checkout for source files so biome (which
# expects LF) stays green across Windows checkouts regardless of core.autocrlf.
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.jsonc    text eol=lf
*.md       text eol=lf
*.sql      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.css      text eol=lf
*.html     text eol=lf

AGENT.md export-ignore
CLAUDE.md export-ignore
RELEASING.md export-ignore
agent-instructions/matchbox-repo-roles.md export-ignore
supabase/migrations/** export-ignore
