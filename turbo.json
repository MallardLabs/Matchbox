{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_ID_URL",
    "NEXT_PUBLIC_DEVELOPER_URL",
    "NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID",
    "SUPABASE_SERVICE_ROLE_KEY",
    "API_KEY_PEPPER",
    "DEVELOPER_API_ORIGIN",
    "API_GATEWAY_SECRET",
    "DEVELOPER_PLATFORM_ENABLED",
    "DEVELOPER_PROFILE_API_ENABLED"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "cloudflare:build": {
      "dependsOn": ["^build"],
      "outputs": [".open-next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
